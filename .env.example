DATABASE_URL=postgresql://username:password@host:5432/database_name
SECRET_KEY=replace_with_a_long_random_secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
ENVIRONMENT=development
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173
VITE_API_BASE_URL=http://localhost:8000

# Development only. Production reset links should be sent by email, not returned in API JSON.
EXPOSE_RESET_LINK_IN_RESPONSE=true

# Password reset email delivery.
# Fill these in production so users receive reset links by email.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Smart Spending Analyzer
SMTP_USE_TLS=true
SMTP_TIMEOUT_SECONDS=10

# Smart import safety limits.
MAX_IMPORT_FILE_BYTES=10485760
MAX_IMPORT_BATCH_FILES=24
MAX_IMPORT_BATCH_BYTES=52428800
MAX_IMPORT_CSV_ROWS=5000
PDF_TEXT_MAX_PAGES=40

# Optional merchant enrichment for unknown statement descriptions.
# Only cleaned merchant names are sent, never amounts, dates, account ids, or full transactions.
GOOGLE_PLACES_API_KEY=
MERCHANT_LOOKUP_REGION=Toronto, Canada
MERCHANT_LOOKUP_REGION_CODE=CA

# Optional free scanned-PDF OCR fallback.
# Requires the Tesseract OCR command to be installed on the backend server.
LOCAL_OCR_ENABLED=true
LOCAL_OCR_COMMAND=tesseract
LOCAL_OCR_LANGUAGE=eng
LOCAL_OCR_TIMEOUT_SECONDS=25
PDF_OCR_RENDER_DPI=200

# Optional AI assistant / OCR provider.
# Keep USE_LLM_ASSISTANT=false for rule-based answers only.
# Set USE_LLM_ASSISTANT=true and provide OPENAI_API_KEY to enable model-backed answers.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4
USE_LLM_ASSISTANT=false
LLM_PROVIDER=auto
LLM_TIMEOUT_SECONDS=20
LLM_MAX_RETRIES=1
LLM_MAX_OUTPUT_TOKENS=700

# Optional local assistant provider using an OpenAI-compatible local endpoint.
USE_LOCAL_LLM=false
LOCAL_LLM_PROVIDER=ollama
LOCAL_LLM_BASE_URL=http://localhost:11434/v1
LOCAL_LLM_MODEL=qwen2.5:7b
LOCAL_LLM_API_KEY=ollama

# Assistant daily safety limits for model-backed answers.
ASSISTANT_DAILY_LLM_LIMIT=100
ASSISTANT_DAILY_LLM_CHAR_LIMIT=150000
